<div class="glass-card" style="max-width: 600px; margin: 0 auto;">
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Webtigo QR Code Generator",
      "operatingSystem": "Any",
      "applicationCategory": "UtilitiesApplication",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "description": "Create high-quality QR codes for URLs, text, and emails for free. Download instantly with no expiration."
    }
    </script>
    <h1 style="margin-bottom: 2rem; text-align: center;">QR Code Generator</h1>
    <p style="text-align: center; color: rgba(255, 255, 255, 0.7); margin-bottom: 2rem; font-size: 1.05rem;">
        Create high-quality QR codes for URLs, text, and emails for <strong>free</strong>. Download instantly with no
        expiration.
    </p>

    <div class="form-group">
        <label>Enter URL or Text</label>
        <input type="text" id="qr-text" placeholder="https://example.com">
    </div>

    <button class="primary-btn" onclick="generateQR()">Generate QR</button>

    <div id="result" class="result-area" style="display: none;">
        <img id="qr-img" src="" alt="QR Code" style="max-width: 100%; border-radius: 8px; margin-bottom: 1rem;">
        <br>
        <a id="download-link" href="#" class="primary-btn"
            style="text-decoration: none; display: inline-block;">Download PNG</a>
    </div>
</div>

<script>
    async function generateQR() {
        const text = document.getElementById('qr-text').value;
        const resultDiv = document.getElementById('result');

        if (!text) return alert('Enter text');

        const formData = new FormData();
        formData.append('data', text);

        try {
            const res = await fetch('/api/generate-qr', { method: 'POST', body: formData });
            if (!res.ok) throw new Error('Failed');

            const blob = await res.blob();
            const url = URL.createObjectURL(blob);

            const img = document.getElementById('qr-img');
            img.src = url;

            const link = document.getElementById('download-link');
            link.href = url;
            link.download = `qrcode-${Date.now()}.png`;

            resultDiv.style.display = 'block';
        } catch (e) {
            alert(e.message);
        }
    }

    window.addEventListener('DOMContentLoaded', () => {
        const params = new URLSearchParams(window.location.search);
        if (params.has('text')) {
            document.getElementById('qr-text').value = decodeURIComponent(params.get('text'));
        }
        if (params.get('auto') === 'true' && params.has('text')) {
            setTimeout(generateQR, 300);
        }
    });

</script>

<section class="glass-card" style="margin-top: 3rem; padding: 3rem; max-width: 800px; margin-left: auto; margin-right: auto;">
    <h2 style="color: white; margin-bottom: 2rem; font-size: 2rem; text-align: center; background: linear-gradient(135deg, white, var(--primary)); -webkit-background-clip: text; background-clip: text; color: transparent; font-weight: 700;">QR Codes Simplified: FAQ</h2>
    
    <div style="display: grid; gap: 2rem; text-align: left;">
        <div>
            <h4 style="color: var(--primary); margin-bottom: 0.5rem; font-size: 1.2rem;">What can I store in a QR Code?</h4>
            <p style="color: var(--text-muted); line-height: 1.6;">Most people use QR codes for website URLs, but you can also store plain text, contact information (vCards), Wi-Fi logins, and even pre-written emails. Our generator specializes in high-speed URL and text encoding.</p>
        </div>

        <div>
            <h4 style="color: var(--primary); margin-bottom: 0.5rem; font-size: 1.2rem;">Do these QR codes expire?</h4>
            <p style="color: var(--text-muted); line-height: 1.6;">No. The QR codes generated by Webtigo are static. This means the data is encoded directly into the pattern of pixels. As long as the pattern is readable, the code will work forever. There are no landing pages or redirects involved.</p>
        </div>

        <div>
            <h4 style="color: var(--primary); margin-bottom: 0.5rem; font-size: 1.2rem;">Can I customize the design?</h4>
            <p style="color: var(--text-muted); line-height: 1.6;">Our current version provides clean, high-contrast black and white squares, which is the most reliable format for scanning across all mobile devices and lighting conditions.</p>
        </div>

        <div>
            <h4 style="color: var(--primary); margin-bottom: 0.5rem; font-size: 1.2rem;">Is it free for commercial use?</h4>
            <p style="color: var(--text-muted); line-height: 1.6;">Yes. You can use these codes on menus, business cards, flyers, and advertisements without any licensing fees. We don't add watermarks to your generated codes.</p>
        </div>
    </div>

    <div style="margin-top: 3rem; padding: 2.5rem; background: rgba(59, 130, 246, 0.05); border-radius: 20px; border: 1px solid rgba(59, 130, 246, 0.2); text-align: center;">
        <h3 style="color: white; margin-bottom: 1rem;">The Science of Scanning</h3>
        <p style="color: var(--text-muted); margin-bottom: 1.5rem;">Did you know QR codes have built-in error correction? Learn how these pixelated squares work in our deep dive guide.</p>
        <a href="/blog/qrcode" class="primary-btn" style="text-decoration: none; display: inline-block; width: auto; padding: 0.75rem 2rem;">Read QR Blog Guide</a>
    </div>
</section>